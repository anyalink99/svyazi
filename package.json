{
  "name": "semantic-codenames",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"tsx watch server/index.ts\" \"vite\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.json --noEmit && vite build",
    "prestart": "npm run build",
    "start": "tsx server/index.ts",
    "prepare:model": "python -m pip install -r requirements-model.txt && python scripts/prepare_model.py",
    "simulate": "tsx scripts/simulate.ts",
    "simulate:full": "tsx scripts/simulate.ts --games 10000 --seed 20260722 --output data/evaluations/10000-games.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/manrope": "^5.2.7",
    "@fontsource/unbounded": "^5.2.7",
    "express": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "trystero": "^0.25.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "playwright-core": "^1.55.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
